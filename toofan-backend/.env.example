# ─────────────────────────────────────────────
#  TooFan Backend — Environment Variables
#  Copy this file to .env and fill in the values
#  NEVER commit .env to git
# ─────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=5000
APP_NAME="TooFan API"
FRONTEND_URL=http://localhost:3000

# Database (PostgreSQL)
DATABASE_URL="postgresql://postgres:yourpassword@localhost:5432/toofan_db?schema=public"

# JWT Secrets  (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=your_jwt_secret_here_change_this
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret_here_change_this
JWT_REFRESH_EXPIRES_IN=30d

# Firebase (Push Notifications)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR KEY HERE\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com

# eSewa Payment (Nepal)
ESEWA_MERCHANT_ID=your_esewa_merchant_id
ESEWA_SECRET_KEY=your_esewa_secret_key
ESEWA_SUCCESS_URL=http://localhost:5000/api/payments/esewa/success
ESEWA_FAILURE_URL=http://localhost:5000/api/payments/esewa/failure

# Khalti Payment (Nepal)
KHALTI_SECRET_KEY=your_khalti_secret_key
KHALTI_PUBLIC_KEY=your_khalti_public_key

# Stripe (International cards fallback)
STRIPE_SECRET_KEY=sk_test_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Google Maps
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# File Uploads (local or S3)
UPLOAD_DRIVER=local
UPLOAD_LOCAL_PATH=./uploads
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=toofan-uploads
# AWS_REGION=ap-south-1

# Email (SMTP — Mailgun or SMTP Nepal)
SMTP_HOST=smtp.mailgun.org
SMTP_PORT=587
SMTP_USER=your@mailgun.org
SMTP_PASS=your_smtp_password
EMAIL_FROM="TooFan <noreply@toofan.com>"

# SMS / WhatsApp (Sparrow SMS Nepal)
SPARROW_SMS_TOKEN=your_sparrow_sms_token
SPARROW_SMS_FROM=TooFan

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Dispatch Config
DISPATCH_RADIUS_KM=5
DISPATCH_OFFER_TIMEOUT_SEC=30

# Master / Team Bypass Login
# Used ONLY for testing — stored in env vars, never in code.
# Set these in Vercel > Settings > Environment Variables (Production + Preview).
# Leave blank or absent to disable the bypass entirely.
MASTER_USER=your_team_username_here
MASTER_PASS=your_strong_team_password_here
DISPATCH_MAX_RETRY=3
